# Environment Variables for AI Business Intelligence Platform
# Copy this file to .env and fill in your actual values

# Backend Configuration
GROQ_API_KEY=your_groq_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
ENVIRONMENT=production

# Frontend Configuration (automatically set by Render)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Database (for future use)
DATABASE_URL=sqlite+aiosqlite:///./ai_biz.db

# CORS Origins (for production, add your frontend URL)
ALLOWED_ORIGINS=["https://your-frontend-app.onrender.com"]