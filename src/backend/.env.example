# Backend Environment Variables
APP_NAME=finance
VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# Groq API Configuration
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TEMPERATURE=0.0
GROQ_API_KEY=your_groq_api_key_here

# Database
DATABASE_URL=sqlite+aiosqlite:///./ai_biz.db

# CORS
ALLOWED_ORIGINS=["*"]

# Logging
LOG_LEVEL=INFO
